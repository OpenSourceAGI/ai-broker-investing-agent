# Kalshi Vibe Bot — copy to .env and fill in values. See README for details.

# ── Kalshi API ────────────────────────────────────────────────────────────────
# Your Kalshi API key id (required for live trading).
KALSHI_API_KEY=
# Path to your RSA private key PEM file.
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem
# Kalshi REST API base URL (use the default unless Kalshi documents otherwise).
KALSHI_BASE_URL=https://api.elections.kalshi.com

# ── AI provider ───────────────────────────────────────────────────────────────
# Default provider for market analysis: gemini or xai (Grok). Overridable in Settings UI.
DEFAULT_AI_PROVIDER=gemini

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Gemini API key (required when DEFAULT_AI_PROVIDER=gemini or when selected in Settings).
# Billed via your Google AI prepaid account. This app does not fetch Gemini balance (no API).
# Get a key: https://ai.google.dev/gemini-api/docs
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Sampling temperature for both Gemini and xAI (lower = more deterministic).
AI_TEMPERATURE=0.1

# ── xAI (Grok) ────────────────────────────────────────────────────────────────
# xAI inference API key (required when DEFAULT_AI_PROVIDER=xai or when selected in Settings).
XAI_API_KEY=
# Grok model id sent to xAI chat/completions.
XAI_MODEL=grok-3
# Optional: xAI team UUID for the prepaid-balance tile on the dashboard.
XAI_TEAM_ID=
# Optional: xAI Management API key (paired with XAI_TEAM_ID; not the inference key).
XAI_MANAGEMENT_API_KEY=

# ── Trading mode ───────────────────────────────────────────────────────────────
# paper = simulated fills; live = real Kalshi orders.
TRADING_MODE=paper
# Starting cash balance for paper mode (USD).
PAPER_STARTING_BALANCE=1000.0

# ── Strategy (Settings UI + DB override after first save) ─────────────────────
# Core knobs you tune in the dashboard. Additional guardrails (max edge, max AI %, Kelly cap,
# sports stricter scan, etc.) are applied automatically in code — see Settings page for summary.
#
# Minimum edge to buy: AI win % on the buy side minus executable ask %, in percentage points.
MIN_EDGE_TO_BUY_PCT=5
# Minimum AI win probability (0–100) on the purchased side before a buy (code clamps 51–99).
MIN_AI_WIN_PROB_BUY_SIDE_PCT=60
# Auto-exit when Est. Value has fallen this fraction vs entry price per contract (0.80 = 80% drawdown).
STOP_LOSS_DRAWDOWN_PCT=0.80
# When false, the bot does not auto-sell on stop-loss (manual sells still work).
STOP_LOSS_SELLING_ENABLED=false
# Max open positions at once; at or over this, new scans and AI analysis pause.
BOT_MAX_OPEN_POSITIONS=30
# How often to poll Kalshi for official outcomes on closed rows still missing a result (seconds; 0 = off).
CLOSED_RESOLUTION_REFRESH_INTERVAL_SEC=450
# Max closed positions checked per outcome poll.
CLOSED_RESOLUTION_REFRESH_BATCH=25
# Minutes after entry before stop-loss auto-exit can trigger (sports get +5 min automatically).
EXIT_GRACE_MINUTES=10

# ── Market scan & liquidity ────────────────────────────────────────────────────
# Seconds between full market scans.
BOT_SCAN_INTERVAL=10
# Minimum 24-hour traded volume (contracts) for a market to be considered (sports floor is higher in code).
BOT_MIN_VOLUME=1500.0
# Prefer markets whose event end is within this many hours (buy vetting window).
BOT_MAX_HOURS=6
# How far ahead to fetch markets from Kalshi by contractual close time (hours).
BOT_MARKETS_FETCH_MAX_CLOSE_HOURS=720
# Max bid–ask spread on the side you buy (decimal dollars; 0.15 = 15¢).
BOT_MAX_SPREAD=0.15
# Minimum top-of-book ask size (contracts) on the side you buy.
BOT_MIN_TOP_SIZE=1.0
# After a stop-loss, wait this many minutes before re-entering the same ticker (0 = off).
REENTRY_COOLDOWN_MINUTES=120
# Minimum gross upside per contract (1 − ask) on the buy leg; scan + pre-buy filter (0 = off).
LOCAL_MIN_RESIDUAL_PAYOFF=0.12

# ── Server ─────────────────────────────────────────────────────────────────────
# HTTP port for the FastAPI backend.
PORT=8000
# Bind address (0.0.0.0 = all interfaces; use 127.0.0.1 to block LAN access).
HOST=0.0.0.0
# When true, enables GET /debug/raw for Kalshi request debugging (keep false in production).
ENABLE_DEBUG_RAW_KALSHI=false
